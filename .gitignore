# Dependencies
/node_modules

# Next.js build output
/.next/
/out/

# Production
/build

# Environment — secrets never enter git history.
# .env.example is the committed contract; everything else stays local.
.env*
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Logs & debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS noise
.DS_Store
Thumbs.db

# Editor state (project settings that SHOULD be shared get whitelisted
# explicitly if the need arises)
.idea/
.vscode/*
!.vscode/extensions.json