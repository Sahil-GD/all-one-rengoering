# ============================================================================
# All One Rengøring — Environment contract
# ----------------------------------------------------------------------------
# Rule: no environment variable exists in the codebase unless documented here.
#
# Copy to `.env.local` for local development. `.env.local` is git-ignored.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser — never put
# secrets behind that prefix.
# ============================================================================

# ----------------------------------------------------------------------------
# Core (required from Phase 1)
# ----------------------------------------------------------------------------

# Absolute origin of the deployed site. Used for canonical URLs, sitemap,
# Open Graph URLs, and JSON-LD. No trailing slash.
# Local:      http://localhost:3000
# Production: https://www.allonerengoering.dk   (placeholder — confirm domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Forms & email delivery (required from Phase 8)
# ----------------------------------------------------------------------------

# Transactional email provider API key (server-only).
# RESEND_API_KEY=

# Mailbox that receives quote/contact notifications.
# QUOTE_NOTIFICATION_EMAIL=

# Verified sender identity for outgoing quote emails (Resend).
# QUOTE_FROM_EMAIL=

# ----------------------------------------------------------------------------
# Future features (documented for planning; commented until their phase)
# ----------------------------------------------------------------------------

# CMS (blog phase)
# SANITY_PROJECT_ID=
# SANITY_DATASET=
# SANITY_API_READ_TOKEN=

# Google Reviews (server-side fetch, reviews phase)
# GOOGLE_PLACES_API_KEY=
# GOOGLE_PLACE_ID=